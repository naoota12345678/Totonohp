{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/dentyo/contact", "destination": "/dentyo-contact.html" },
    { "source": "/dentyo/guide", "destination": "/dentyo-guide.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ]
}
